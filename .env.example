# --- Database ---
# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://brevklar:brevklar@localhost:5432/brevklar?schema=public"

# --- AI (Anthropic / Claude) ---
ANTHROPIC_API_KEY="sk-ant-..."
# Modellen som driver analysmotorn. Standard: Anthropics mest kapabla modell.
BREVKLAR_AI_MODEL="claude-opus-4-8"

# --- Auth / BankID ---
# JWT-hemlighet för sessionstokens som utfärdas efter BankID-inloggning.
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
# Sätt till "true" i utveckling för att kunna testa utan riktig BankID-uppkoppling.
BANKID_MOCK_ENABLED="true"
# Produktion: sökväg till klientcertifikat mot BankID:s API (RP-cert).
BANKID_API_URL="https://appapi2.test.bankid.com/rp/v6.0"
BANKID_CLIENT_CERT_PATH=""
BANKID_CA_CERT_PATH=""

# --- Server ---
PORT="3000"
NODE_ENV="development"
